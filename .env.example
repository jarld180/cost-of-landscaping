# ===========================================
# Cost of Concrete - Environment Variables
# ===========================================
# Copy this file to .env.local for local development
# Do NOT commit .env.local to version control

# ===========================================
# Supabase Configuration
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# Background Job Runner
# ===========================================
# Secret for authenticating job execution requests from pg_cron
# Generate with: openssl rand -hex 32
JOB_RUNNER_SECRET=your-secure-secret-here

# ===========================================
# Bulk Operations
# ===========================================
# Maximum number of contractors that can be updated/deleted in a single bulk operation
# Default: 100 (recommended for production)
# Note: The UI will cap this at 100 for safety to avoid URI too long errors
# Development: Can be increased for testing, but UI will still cap at 100
BULK_OPERATION_LIMIT=100

# ===========================================
# Supabase Vault Configuration (set via Dashboard)
# ===========================================
# These secrets must be set in Supabase Dashboard > Project Settings > Vault
# - JOB_RUNNER_API_URL: Your production API URL (e.g., https://costofconcrete.com)
# - JOB_RUNNER_SECRET: Same value as above, for pg_cron to authenticate

# ===========================================
# Observability (Optional)
# ===========================================
# Helicone API key for LLM observability (traces all AI calls)
# Sign up at https://helicone.ai and get your API key
# If not set, pipeline works normally without tracing
# Note: NUXT_ prefix required - maps to runtimeConfig.heliconeApiKey
NUXT_HELICONE_API_KEY=

